# NOTE: creating this file makes Vercel stop respecting .gitignore automatically,
# so every pattern below is mirrored from .gitignore first, then the additional
# internal-docs exclusions are appended after. Keep both files in sync.

# dependencies
node_modules

# testing
coverage

# next.js
.next
out

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files — never ship real secrets; Vercel's own dashboard env vars are used instead
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local config (never needed at runtime)
.claude

# internal planning/process docs — not part of the shipped app
docs
.superpowers
prototype-extract
CLAUDE.md
AGENTS.md
App gestión inventarios motos.zip
